# Illumin environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local -- it is in .gitignore.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase)
# DATABASE_URL is the transaction-mode pooler used by the runtime for all queries.
#   host: aws-<region>.pooler.supabase.com, port: 6543, user: postgres.<project_ref>
#   params: ?pgbouncer=true&connection_limit=1 (one pool seat per serverless lambda)
# DIRECT_URL is the direct (non-pooler) connection used only by Prisma for migrations
# and introspection. It must bypass PgBouncer.
#   host: db.<project_ref>.supabase.co, port: 5432, user: postgres, no pgbouncer params
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres

# Prisma migrate dev shadow database. Must point to a separate, empty Supabase project in the same region as production.
SHADOW_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
# PLAID_ENV=sandbox  # or development, production

# Resend (email)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=

# Admin
# ADMIN_EMAILS is the authoritative server-side allowlist. Comma-separated, no
# whitespace required. All /admin routes and the getPostAuthRedirect helper
# consult this list. Never commit real values.
# ADMIN_EMAILS=you@example.com,teammate@example.com
#
# NEXT_PUBLIC_ADMIN_EMAIL is the client-side hint used to render admin-only UI
# affordances (Header admin pill). It is intentionally a single email, not the
# full list, since the full list should not be exposed to the browser.
# NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# Internal scan endpoint (/api/internal/scan) shared secret.
# Used by the scheduler and any server-side trigger to authenticate scan
# requests. Generate a high-entropy random string and set separately in
# Vercel and .env.local. Never ship this to the browser.
INTERNAL_SCAN_SECRET=
